# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# REPLICATE_API_TOKEN: Optional for cloud execution. If empty, local CLI execution mode will be active!
REPLICATE_API_TOKEN=""

# LOCAL OFFLINE MODE CONFIGURATION
# Step 1: Local Demucs configuration
# The command or path to the demucs executable. Can be 'demucs', 'python -m demucs', etc.
LOCAL_DEMUCS_CMD="demucs"
# Custom arguments template for Demucs. Supports placeholders: {input_file} and {output_dir}
LOCAL_DEMUCS_ARGS="--two-stems=vocals --mp3 -o {output_dir} {input_file}"

# Step 3: Local RVC Voice Swap configuration
# The Python command (e.g., 'python', 'python3', '/path/to/venv/bin/python') or binary.
LOCAL_RVC_CMD="python"
# Path to your RVC inference script (e.g., 'rvc_cli.py', 'infer_cli.py', or custom tool script).
LOCAL_RVC_SCRIPT="rvc_cli.py"
# Arguments template for the RVC script. Supports placeholders: {input_vocals}, {voice_sample}, {output_cloned}
LOCAL_RVC_ARGS="-i {input_vocals} -m {voice_sample} -o {output_cloned}"
